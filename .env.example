# Local dev only. Cloud Run uses Secret Manager via deploy-cloudrun.sh
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

GCP_PROJECT_ID=athlete-ai-platform
GCP_LOCATION=us-central1

# Local polling only — not required without WEBHOOK_URL
# WEBHOOK_SECRET=
# WEBHOOK_URL=

# Optional: hours between /getnews runs (default 4, set in deploy-cloudrun.sh for Cloud Run)
# DIGEST_COOLDOWN_HOURS=4

# Optional: persist generated digest .md locally (off by default)
# SAVE_DIGEST_FILE=true
# DIGESTS_DIR=digests

# Optional TTS override (default: en-US-Neural2-J)
# TTS_VOICE=en-US-Neural2-J
